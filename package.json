{
  "name": "marked-react",
  "version": "3.0.2",
  "description": "Render Markdown as React components",
  "keywords": [
    "markdown",
    "marked",
    "markedjs",
    "no dangerouslySetInnerHTML",
    "react"
  ],
  "homepage": "https://github.com/sibiraj-s/marked-react#readme",
  "bugs": "https://github.com/sibiraj-s/marked-react/issues",
  "license": "MIT",
  "author": "sibiraj-s",
  "repository": "github:sibiraj-s/marked-react",
  "files": [
    "dist/"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "oxlint .",
    "build": "tsdown",
    "dev": "storybook dev -p 7007",
    "build:storybook": "storybook build",
    "test": "vitest --coverage",
    "prepare": "is-ci || husky",
    "prepublishOnly": "is-ci || (npm run build && publint)"
  },
  "dependencies": {
    "html-entities": "^2.6.0",
    "marked": "^17.0.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@storybook/react": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "commitlint-config-non-conventional": "^1.0.1",
    "highlight.js": "^11.11.1",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.3.3",
    "oxfmt": "^0.39.0",
    "oxlint": "^1.54.0",
    "publint": "^0.3.18",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-lowlight": "^3.1.0",
    "storybook": "^10.2.17",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": "^16.8.0 || >=17.0.0"
  }
}
